{
  "uid": "api-overview",
  "title": "API — Vue Principale (N1)",
  "description": "Dashboard de supervision N1 : disponibilité, trafic, erreurs, latence, saturation système",
  "tags": [
    "api",
    "slo",
    "overview"
  ],
  "timezone": "browser",
  "refresh": "30s",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "templating": {
    "list": [
      {
        "name": "endpoint",
        "label": "Endpoint",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "prometheus-uid"
        },
        "query": "label_values(http_requests_total, endpoint)",
        "includeAll": true,
        "allValue": ".*",
        "multi": false,
        "refresh": 2
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "🟢 Service UP ?",
      "type": "stat",
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 4,
        "h": 4
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus-uid"
      },
      "targets": [
        {
          "expr": "up{job=\"demo-api\"}",
          "legendFormat": "API",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus-uid"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {
              "type": "value",
              "options": {
                "1": {
                  "text": "UP",
                  "color": "green"
                },
                "0": {
                  "text": "DOWN",
                  "color": "red"
                }
              }
            }
          ],
          "thresholds": {
            "steps": [
              {
                "value": 0,
                "color": "red"
              },
              {
                "value": 1,
                "color": "green"
              }
            ]
          },
          "color": {
            "mode": "thresholds"
          }
        }
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background"
      }
    },
    {
      "id": 2,
      "title": "✅ Taux de succès (SLO : ≥ 99,5%)",
      "type": "stat",
      "gridPos": {
        "x": 4,
        "y": 0,
        "w": 5,
        "h": 4
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus-uid"
      },
      "targets": [
        {
          "expr": "1 - (sum(rate(http_requests_total{status_code=~\"5..\"}[5m])) / sum(rate(http_requests_total[5m])))",
          "legendFormat": "Disponibilité",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus-uid"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": {
            "steps": [
              {
                "value": 0,
                "color": "red"
              },
              {
                "value": 0.995,
                "color": "green"
              }
            ]
          },
          "color": {
            "mode": "thresholds"
          },
          "min": 0,
          "max": 1
        }
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "background"
      }
    },
    {
      "id": 3,
      "title": "⏱ Latence p95 (SLO : ≤ 500ms)",
      "type": "stat",
      "gridPos": {
        "x": 9,
        "y": 0,
        "w": 5,
        "h": 4
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus-uid"
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "p95",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus-uid"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "steps": [
              {
                "value": 0,
                "color": "green"
              },
              {
                "value": 0.5,
                "color": "orange"
              },
              {
                "value": 1.0,
                "color": "red"
              }
            ]
          },
          "color": {
            "mode": "thresholds"
          }
        }
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "background"
      }
    },
    {
      "id": 4,
      "title": "📊 Trafic (requêtes/s)",
      "type": "stat",
      "gridPos": {
        "x": 14,
        "y": 0,
        "w": 4,
        "h": 4
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus-uid"
      },
      "targets": [
        {
          "expr": "sum(rate(http_requests_total[2m]))",
          "legendFormat": "req/s",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus-uid"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "color": {
            "mode": "palette-classic"
          }
        }
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "value"
      }
    },
    {
      "id": 5,
      "title": "🔥 Trafic — Requêtes/s par endpoint",
      "type": "timeseries",
      "gridPos": {
        "x": 0,
        "y": 4,
        "w": 12,
        "h": 8
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus-uid"
      },
      "targets": [
        {
          "expr": "sum(rate(http_requests_total{endpoint=~\"$endpoint\"}[2m])) by (endpoint)",
          "legendFormat": "{{ endpoint }}",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus-uid"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10
          }
        }
      },
      "options": {
        "tooltip": {
          "mode": "multi"
        }
      }
    },
    {
      "id": 6,
      "title": "❌ Taux d'erreur par code HTTP",
      "type": "timeseries",
      "gridPos": {
        "x": 12,
        "y": 4,
        "w": 12,
        "h": 8
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus-uid"
      },
      "targets": [
        {
          "expr": "sum(rate(http_requests_total{status_code=~\"4..\"}[5m])) by (endpoint)",
          "legendFormat": "4xx – {{ endpoint }}",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus-uid"
          }
        },
        {
          "expr": "sum(rate(http_requests_total{status_code=~\"5..\"}[5m])) by (endpoint)",
          "legendFormat": "5xx – {{ endpoint }}",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus-uid"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 15
          },
          "color": {
            "mode": "palette-classic"
          }
        }
      }
    },
    {
      "id": 7,
      "title": "📈 Latence — p50 / p95 / p99",
      "type": "timeseries",
      "gridPos": {
        "x": 0,
        "y": 12,
        "w": 12,
        "h": 8
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus-uid"
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(http_request_duration_seconds_bucket{endpoint=~\"$endpoint\"}[5m])) by (le))",
          "legendFormat": "p50",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus-uid"
          }
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket{endpoint=~\"$endpoint\"}[5m])) by (le))",
          "legendFormat": "p95",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus-uid"
          }
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(http_request_duration_seconds_bucket{endpoint=~\"$endpoint\"}[5m])) by (le))",
          "legendFormat": "p99",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus-uid"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "lineWidth": 2
          },
          "thresholds": {
            "steps": [
              {
                "value": 0.5,
                "color": "orange"
              }
            ]
          }
        }
      }
    },
    {
      "id": 8,
      "title": "🖥 CPU système (%)",
      "type": "timeseries",
      "gridPos": {
        "x": 12,
        "y": 12,
        "w": 12,
        "h": 8
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus-uid"
      },
      "targets": [
        {
          "expr": "100 - (avg(rate(node_cpu_seconds_total{mode=\"idle\"}[2m])) * 100)",
          "legendFormat": "CPU utilisé %",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus-uid"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "steps": [
              {
                "value": 0,
                "color": "green"
              },
              {
                "value": 80,
                "color": "orange"
              },
              {
                "value": 90,
                "color": "red"
              }
            ]
          },
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 20
          }
        }
      }
    },
    {
      "id": 9,
      "title": "💾 Mémoire disponible",
      "type": "timeseries",
      "gridPos": {
        "x": 0,
        "y": 20,
        "w": 12,
        "h": 7
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus-uid"
      },
      "targets": [
        {
          "expr": "node_memory_MemAvailable_bytes",
          "legendFormat": "Mémoire disponible",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus-uid"
          }
        },
        {
          "expr": "node_memory_MemTotal_bytes",
          "legendFormat": "Mémoire totale",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus-uid"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10
          }
        }
      }
    },
    {
      "id": 10,
      "title": "🏆 Top 5 endpoints par trafic",
      "type": "bargauge",
      "gridPos": {
        "x": 12,
        "y": 20,
        "w": 12,
        "h": 7
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus-uid"
      },
      "targets": [
        {
          "expr": "topk(5, sum(rate(http_requests_total[5m])) by (endpoint))",
          "legendFormat": "{{ endpoint }}",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus-uid"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "color": {
            "mode": "palette-classic"
          }
        }
      },
      "options": {
        "orientation": "horizontal",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "displayMode": "gradient",
        "links": [
          {
            "title": "Diagnostic endpoint",
            "url": "/d/api-diagnostic?var-endpoint=${__field.labels.endpoint}",
            "targetBlank": false
          }
        ]
      }
    }
  ],
  "schemaVersion": 39
}