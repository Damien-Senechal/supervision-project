{
  "uid": "api-diagnostic",
  "title": "API — Diagnostic (N2)",
  "description": "Dashboard N2 : investigation fine par endpoint, distribution de latence, erreurs détaillées",
  "tags": [
    "api",
    "diagnostic",
    "n2"
  ],
  "timezone": "browser",
  "refresh": "15s",
  "time": {
    "from": "now-30m",
    "to": "now"
  },
  "templating": {
    "list": [
      {
        "name": "endpoint",
        "label": "Endpoint",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "prometheus-uid"
        },
        "query": "label_values(http_requests_total, endpoint)",
        "includeAll": false,
        "refresh": 2
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "Taux d'erreur — $endpoint",
      "type": "timeseries",
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 12,
        "h": 8
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus-uid"
      },
      "targets": [
        {
          "expr": "sum(rate(http_requests_total{endpoint=\"$endpoint\", status_code=~\"5..\"}[2m]))",
          "legendFormat": "5xx",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus-uid"
          }
        },
        {
          "expr": "sum(rate(http_requests_total{endpoint=\"$endpoint\", status_code=~\"4..\"}[2m]))",
          "legendFormat": "4xx",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus-uid"
          }
        },
        {
          "expr": "sum(rate(http_requests_total{endpoint=\"$endpoint\", status_code=~\"2..\"}[2m]))",
          "legendFormat": "2xx",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus-uid"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10
          }
        }
      }
    },
    {
      "id": 2,
      "title": "Distribution latence — $endpoint (heatmap buckets)",
      "type": "timeseries",
      "gridPos": {
        "x": 12,
        "y": 0,
        "w": 12,
        "h": 8
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus-uid"
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(http_request_duration_seconds_bucket{endpoint=\"$endpoint\"}[5m])) by (le))",
          "legendFormat": "p50",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus-uid"
          }
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket{endpoint=\"$endpoint\"}[5m])) by (le))",
          "legendFormat": "p95",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus-uid"
          }
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(http_request_duration_seconds_bucket{endpoint=\"$endpoint\"}[5m])) by (le))",
          "legendFormat": "p99",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus-uid"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "lineWidth": 2
          }
        }
      }
    },
    {
      "id": 3,
      "title": "Requêtes en cours (in-progress)",
      "type": "timeseries",
      "gridPos": {
        "x": 0,
        "y": 8,
        "w": 8,
        "h": 7
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus-uid"
      },
      "targets": [
        {
          "expr": "http_requests_in_progress{endpoint=\"$endpoint\"}",
          "legendFormat": "{{ method }} {{ endpoint }}",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus-uid"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "lineWidth": 2
          }
        }
      }
    },
    {
      "id": 4,
      "title": "Répartition des codes HTTP — $endpoint",
      "type": "piechart",
      "gridPos": {
        "x": 8,
        "y": 8,
        "w": 8,
        "h": 7
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus-uid"
      },
      "targets": [
        {
          "expr": "sum(increase(http_requests_total{endpoint=\"$endpoint\"}[30m])) by (status_code)",
          "legendFormat": "HTTP {{ status_code }}",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus-uid"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {
            "mode": "palette-classic"
          }
        }
      }
    },
    {
      "id": 5,
      "title": "Saturation — CPU par mode",
      "type": "timeseries",
      "gridPos": {
        "x": 16,
        "y": 8,
        "w": 8,
        "h": 7
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus-uid"
      },
      "targets": [
        {
          "expr": "avg(rate(node_cpu_seconds_total{mode!=\"idle\"}[2m])) by (mode) * 100",
          "legendFormat": "{{ mode }}",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus-uid"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100
        }
      }
    }
  ],
  "schemaVersion": 39
}